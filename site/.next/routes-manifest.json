{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/investing/companies/[ticker]",
      "regex": "^/investing/companies/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPticker": "nxtPticker"
      },
      "namedRegex": "^/investing/companies/(?<nxtPticker>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/daily",
      "regex": "^/daily(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/daily(?:/)?$"
    },
    {
      "page": "/investing",
      "regex": "^/investing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/investing(?:/)?$"
    },
    {
      "page": "/investing/journal",
      "regex": "^/investing/journal(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/investing/journal(?:/)?$"
    },
    {
      "page": "/investing/journey",
      "regex": "^/investing/journey(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/investing/journey(?:/)?$"
    },
    {
      "page": "/investing/watchlist",
      "regex": "^/investing/watchlist(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/investing/watchlist(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}